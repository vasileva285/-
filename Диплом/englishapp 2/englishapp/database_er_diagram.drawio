        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;b&gt;УСЛОВНЫЕ ОБОЗНАЧЕНИЯ&lt;/b&gt;&lt;hr&gt;&lt;table border=&quot;0&quot; cellpadding=&quot;5&quot; cellspacing=&quot;0&quot; style=&quot;width:100%&quot;&gt;&lt;tr&gt;&lt;td bgcolor=&quot;#ffcccc&quot; width=&quot;30&quot;&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;PK&lt;/b&gt; - Primary Key (Первичный ключ)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td bgcolor=&quot;#ccccff&quot; width=&quot;30&quot;&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;FK&lt;/b&gt; - Foreign Key (Внешний ключ)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td bgcolor=&quot;#ccffcc&quot; width=&quot;30&quot;&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;UQ&lt;/b&gt; - Unique (Уникальное значение)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;One (Один)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;N&lt;/td&gt;&lt;td&gt;Many (Много)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" vertex="1">
