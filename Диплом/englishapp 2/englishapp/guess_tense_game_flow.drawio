<mxfile host="app.diagrams.net">
  <diagram name="Игра Угадай время">
    <mxGraphModel dx="827" dy="1169" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Блоки -->
        <mxCell id="startGT" value="Старт игры &quot;Угадай время&quot;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="40" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="openLessonGT" value="Пользователь открывает урок-игру в приложении" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="380" height="60" as="geometry" />
        </mxCell>

        <mxCell id="loadTaskGT" value="Система загружает из БД задание (предложение или короткая история + список времён)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="210" width="420" height="100" as="geometry" />
        </mxCell>

        <mxCell id="showTaskGT" value="Отобразить текст задания и варианты времён (Present, Past, Future и т.п.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="420" height="80" as="geometry" />
        </mxCell>

        <mxCell id="userChoiceGT" value="Пользователь выбирает одно время" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="380" height="60" as="geometry" />
        </mxCell>

        <mxCell id="sendGT" value="Отправить выбранное время на сервер" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="520" width="380" height="60" as="geometry" />
        </mxCell>

        <mxCell id="checkGT" value="Сервер сравнивает выбранное время с правильным ответом из БД" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="610" width="420" height="60" as="geometry" />
        </mxCell>

        <mxCell id="decisionGT" value="Время выбрано верно?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="190" y="700" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="correctGT" value="Начислить баллы и обновить прогресс урока (если это первая правильная попытка)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="80" y="800" width="420" height="80" as="geometry" />
        </mxCell>

        <mxCell id="wrongGT" value="Сохранить попытку как неверную и вернуть правильное время с объяснением" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="540" y="800" width="420" height="100" as="geometry" />
        </mxCell>

        <mxCell id="frontendGT" value="Фронтенд показывает результат и объяснение пользователю" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="540" y="930" width="420" height="80" as="geometry" />
        </mxCell>

        <mxCell id="endGT" value="Игра завершена (все задания решены верно хотя бы один раз)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="580" y="1030" width="340" height="60" as="geometry" />
        </mxCell>

        <!-- Стрелки -->
        <mxCell id="egt1" edge="1" parent="1" source="startGT" target="openLessonGT" style="endArrow=block;strokeColor=#6c8ebf;">
